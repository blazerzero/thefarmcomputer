# Copy this file to .env and fill in your values.

# Required: your Discord bot token
DISCORD_TOKEN=your_discord_bot_token_here

# Optional: restrict slash command registration to one guild during development
# Leave blank to register commands globally (may take up to 1 hour to propagate)
GUILD_ID=

# Optional: role ID whose members can use /update to trigger a manual wiki refresh
# Leave blank to allow anyone with the Administrator permission
ADMIN_ROLE_ID=

# How often to refresh the wiki knowledge base (hours). Default: 168 (1 week)
UPDATE_INTERVAL_HOURS=168
